{
  // jsonstat-wasm type-check configuration.
  //
  // The shipped type surface (pkg/jsonstat_wasm.d.ts) is generated by
  // wasm-bindgen. The generated classes declare [Symbol.dispose]() so that
  // callers can use `using ds = new JSONstat(...)` for deterministic WASM
  // memory release. `Symbol.dispose` is defined in
  // lib.esnext.disposable.d.ts, which is NOT part of the older default lib
  // bundle, so the TS server reported:
  //   TS2550: Property 'dispose' does not exist on type 'SymbolConstructor'
  // at pkg/jsonstat_wasm.d.ts:21 and :66.
  //
  // Fix: declare an explicit `lib` that includes "ESNext". This both silences
  // the error for this repo and serves as the recommended baseline for any
  // downstream consumer that type-checks the package.
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],

    // Type-checking only: the JS/WASM artifacts are produced by the Rust
    // toolchain (wasm-bindgen), not by tsc.
    "noEmit": true,

    // Only check the generated type definitions; the hand-written test/ demo
    // .js files are plain ES modules outside TS's contract.
    "allowJs": false,

    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "exactOptionalPropertyTypes": true
  },
  "include": ["pkg/**/*.d.ts"]
}
